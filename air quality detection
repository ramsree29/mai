import pandas as pd 
import numpy as np 
from sklearn.model_selection import train_test_split 
from sklearn.linear_model import LinearRegression 
from sklearn.preprocessing import StandardScaler 
from sklearn.metrics import mean_absolute_error, 
mean_squared_error 
# 2. LOAD AND CLEAN DATASET 
df = pd.read_csv("Airquality.csv",decimal=',') 
df.replace(-200, np.nan, inplace=True) 
df.fillna(df.mean(numeric_only=True), inplace=True) 
# Convert 'Date' column to datetime 
df['Date'] = pd.to_datetime(df['Date'], errors='coerce') 
df['hour'] = pd.to_datetime(df['Time'],format="%H:%M:%S", 
errors='coerce').dt.hour 
# 3. FEATURE ENGINEERING 
features = ['PT08.S1(CO)', 'PT08.S2(NMHC)', 'PT08.S3(NOx)', 
'PT08.S4(NO2)', 'PT08.S5(O3)', 'T', 'RH', 'AH'] 
targets = ['CO(GT)', 'NMHC(GT)', 'NOx(GT)', 'NO2(GT)', 'C6H6(GT)'] 
# 4. TRAIN AND SAVE MODELS 
for target in targets: 
print(f"\nTraining Linear Regression for: {target}") 
X = df[features] 
y = df[target] 
scaler = StandardScaler() 
X_scaler = scaler.fit_transform(X) 
X_train, X_test, y_train, y_test = train_test_split(X_scaler, y, 
test_size=0.2, random_state=42) 
model = LinearRegression().fit(X_train, y_train) 
y_pred = model.predict(X_test) 
mae = mean_absolute_error(y_test, y_pred) 
mse = mean_squared_error(y_test, y_pred) 
print(f"MAE: {mae:.2f} | MSE: {mse:.2f}") 
